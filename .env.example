# Copy this file to .env and fill in the values.
# .env is excluded from version control.

# PostgreSQL
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Airflow security keys (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=

# Airflow users created on first start
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

AIRFLOW_OP_USER=user_devops
AIRFLOW_OP_PASSWORD=user_devops
AIRFLOW_OP_EMAIL=op@example.com

AIRFLOW_USER_USER=user_user
AIRFLOW_USER_PASSWORD=user_user
AIRFLOW_USER_EMAIL=user@example.com

AIRFLOW_VIEWER_USER=user_viewer
AIRFLOW_VIEWER_PASSWORD=user_viewer
AIRFLOW_VIEWER_EMAIL=viewer@example.com

# UID of the host user — avoids permission issues on mounted volumes
# Run: echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000

# Optional: extra pip packages to install at container startup (space-separated)
_PIP_ADDITIONAL_REQUIREMENTS=
